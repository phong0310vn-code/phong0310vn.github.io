<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Navigation Bar Solution</title>
    <style>
        /* Nội dung lấy từ ảnh Solution: Navigation Bar (CSS) */
        
        body {
            margin: 0;
            padding: 0;
            background: #ccc; /* Màu nền xám nhạt của trang */
        }

        nav#topmenu ul {
            list-style: none; /* Bỏ dấu chấm đầu dòng */
            background-color: #444; /* Màu nền tối của thanh menu */
            text-align: center; /* Căn giữa các mục trong menu */
            padding: 0;
            margin: 0;
        }

        nav#topmenu li {
            font-size: 24px;
            line-height: 40px;
            height: 40px;
            display: inline-block; /* Sắp xếp các mục nằm ngang */
            padding: 20px;
        }

        nav#topmenu a {
            text-decoration: none; /* Bỏ gạch chân của liên kết */
            color: #fff; /* Chữ màu trắng */
        }
    </style>
</head>
<body>

    <nav id="topmenu">
        <ul>
            <li><a href="#">Home</a></li>
            <li><a href="#">Tutorials</a></li>
            <li><a href="#">About</a></li>
            <li><a href="#">Newsletter</a></li>
            <li><a href="#">Contact</a></li>
        </ul>
    </nav>

</body>
</html>